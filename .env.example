# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Snowflake account identifier (e.g. xy12345.us-east-1)
SNOWFLAKE_ACCOUNT=

# Snowflake username
SNOWFLAKE_USER=

# Key-pair auth (preferred) — path to your private key file
SNOWFLAKE_PRIVATE_KEY_PATH=/Users/marcalexander/.ssh/snowflake/rsa_key.p8
# SNOWFLAKE_PRIVATE_KEY_PASSPHRASE=   # only if key is passphrase-protected

# Password auth (fallback) — uncomment password line in config_snowflake.yaml too
# SNOWFLAKE_PASSWORD=

SNOWFLAKE_WAREHOUSE=LOADING
SNOWFLAKE_ROLE=TRANSFORMER

# ── Anthropic Claude API (used by ml/demand_prediction/ai/briefing.py) ──
# Preferred: keep this key OUT of the project entirely, in ~/.anthropic/.env
#   mkdir -p ~/.anthropic
#   echo "ANTHROPIC_API_KEY=sk-ant-..." > ~/.anthropic/.env
#   chmod 600 ~/.anthropic/.env
# briefing.py loads it from there automatically. Same convention as
# ~/.dbt/profiles.yml and ~/.ssh/snowflake/ — credentials live in the
# user's home, never inside any project tree.
#
# Uncomment + fill in below ONLY if you want a project-local override.
# ANTHROPIC_API_KEY=
